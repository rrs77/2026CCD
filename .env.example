# Supabase Auth - set VITE_USE_SUPABASE_AUTH=true to use email/password login
VITE_USE_SUPABASE_AUTH=true
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Production app URL – used so password reset emails contain the correct link (not localhost)
# VITE_APP_URL=https://www.ccdesigner.co.uk

# Local dev / non-Vercel host: point API calls (create-user, resend-invite) to your Vercel deployment
# VITE_VERCEL_URL=https://your-app.vercel.app
